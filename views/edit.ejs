<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Редагувати петицію</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Редагування петиції</h1>
    <form action="/update/<%= petition.id %>" method="POST">
        <input type="text" name="title" value="<%= petition.title %>" required>
        <textarea name="description" required><%= petition.description %></textarea>
        <button type="submit">Зберегти зміни</button>
        <button type="button" onclick="window.location.href = '/';">Скасувати</button>
    </form>
</body>
</html>